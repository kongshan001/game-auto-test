# GLM API配置
GLM_API_KEY=your_api_key_here
GLM_MODEL=glm-4v

# 游戏配置
GAME_EXE_PATH=C:\Games\MyGame\game.exe
GAME_WINDOW_TITLE=MyGame
GAME_STARTUP_DELAY=5

# 测试配置
TEST_CASE=测试登录：输入用户名'admin'，密码'123'，点击登录，验证进入主界面
MAX_STEPS=100
STEP_TIMEOUT=30

# 日志配置
LOG_LEVEL=INFO
SCREENSHOT_SAVE_PATH=./logs/screenshots
SAVE_SCREENSHOTS=true

# 视觉配置
OCR_ENABLED=true
OCR_LANGUAGES=ch_sim,en

# 动作配置
CLICK_DELAY=0.5
TYPE_DELAY=0.1
KEYPRESS_DELAY=0.3
